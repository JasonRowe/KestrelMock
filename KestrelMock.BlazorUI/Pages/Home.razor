@page "/"
@using MudBlazor

<PageTitle>Live Dashboard</PageTitle>

<MudGrid>
    @* Left Column: Active Mocks *@
    <MudItem xs="12" md="5" lg="4">
        <MudPaper Elevation="2" Class="pa-4 d-flex flex-column" Style="height: calc(100vh - 120px); overflow: hidden;">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6">Active Mocks</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add">New Mock</MudButton>
            </div>
            
            <MudList T="HttpMockSetting" Dense="true" Class="flex-grow-1 overflow-auto">
                @if (_mocks == null)
                {
                    <div class="d-flex justify-center align-center h-100">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    </div>
                }
                else if (!_mocks.Any())
                {
                    <div class="pa-4 mud-text-secondary text-center">
                        <MudText Typo="Typo.body2">No mocks active.</MudText>
                    </div>
                }
                else
                {
                    @foreach (var mock in _mocks)
                    {
                        var method = mock.Request?.GetDisplayMethod() ?? "ANY";
                        var path = mock.Request?.GetDisplayPath() ?? "Unknown";

                        <MudListItem Class="pa-0 mb-2">
                            <MudCard Elevation="1" Class="pa-2">
                                <div class="d-flex align-center">
                                    <MudChip T="string" Size="Size.Small" Color="@GetMethodColor(method)" Class="mr-2">@method</MudChip>
                                    <MudText Typo="Typo.body2" Class="text-truncate">@path</MudText>
                                    <MudSpacer />
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                                </div>
                                @if (mock.Watch != null)
                                {
                                    <div class="mt-1">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Visibility">Observed</MudChip>
                                    </div>
                                }
                            </MudCard>
                        </MudListItem>
                    }
                }
            </MudList>
        </MudPaper>
    </MudItem>

    @* Right Column: Live Web Traffic Feed *@
    <MudItem xs="12" md="7" lg="8">
        <MudPaper Elevation="2" Class="pa-4 d-flex flex-column" Style="height: calc(100vh - 120px); overflow: hidden;">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6">Live Traffic Feed</MudText>
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Size="Size.Small" Class="mr-2 blink-animation" />
                    <MudText Typo="Typo.body2" Color="Color.Success">Connected</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.ClearAll" Size="Size.Small" Class="ml-4" title="Clear Log" />
                </div>
            </div>

            <div class="flex-grow-1 overflow-auto bg-darker pa-2 rounded" style="background-color: var(--mud-palette-background-grey);">
                @if (!_liveTraffic.Any())
                {
                    <div class="d-flex justify-center align-center h-100 mud-text-secondary">
                        <MudText Typo="Typo.body2">No traffic received yet. Send a request to an observed mock.</MudText>
                    </div>
                }
                
                @foreach (var log in _liveTraffic)
                {
                    <MudCard Elevation="0" Class="mb-2 pa-2 border-solid border-2 mud-border-dark">
                        <div class="d-flex align-center">
                            <MudText Typo="Typo.caption" Class="mr-3 mud-text-secondary">@log.Timestamp.ToString("HH:mm:ss.fff")</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetMethodColor(log.Method)" Class="mr-2">@log.Method</MudChip>
                            <MudText Typo="Typo.body2" Class="font-monospace text-truncate" Style="max-width: 400px;">@log.Path</MudText>
                            <MudSpacer />
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(log.StatusCode)" Variant="Variant.Filled">@log.StatusCode</MudChip>
                        </div>
                    </MudCard>
                }
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<style>
    .blink-animation {
        animation: blinker 2s linear infinite;
    }
    @@keyframes blinker {
        50% { opacity: 0.3; }
    }
    .bg-darker {
        background-color: rgba(0,0,0, 0.2);
    }
</style>

@code {
    @using Microsoft.AspNetCore.SignalR.Client
    @using System.Net.Http.Json
    @using KestrelMock.BlazorUI.Models
    @inject NavigationManager Navigation
    @inject HttpClient Http

    private HubConnection? _hubConnection;
    private bool _isConnected => _hubConnection?.State == HubConnectionState.Connected;

    private List<HttpMockSetting>? _mocks;

    private List<TrafficLog> _liveTraffic = new();

    protected override async Task OnInitializedAsync()
    {
        // Try connecting to the local mock server instance.
        // We will default to http://localhost:5000/kestrelmock/hub/traffic as per standard KestrelMock usage
        // but we should eventually make this configurable in UI settings.
        var targetUrl = "http://localhost:5000/kestrelmock/hub/traffic";

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(targetUrl)
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<TrafficLog, Guid>("ReceiveTraffic", (log, watchId) =>
        {
            // Optional: match watchId to _dummyMocks to enrich data
            _liveTraffic.Insert(0, log); // Prepend to top
            if (_liveTraffic.Count > 100)
            {
                _liveTraffic.RemoveAt(_liveTraffic.Count - 1); // Keep last 100
            }
            StateHasChanged();
        });

        try
        {
            await _hubConnection.StartAsync();
            
            // Fetch live mocks from the server
            var httpClient = new HttpClient { BaseAddress = new Uri("http://localhost:5000") };
            var fetchedMocks = await httpClient.GetFromJsonAsync<List<HttpMockSetting>>("/kestrelmock/mocks");
            if (fetchedMocks != null)
            {
                _mocks = fetchedMocks;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error connecting to SignalR or fetching mocks: {ex.Message}");
            _mocks = new List<HttpMockSetting>();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is null) return;
        
        await _hubConnection.DisposeAsync();
    }

    private Color GetMethodColor(string method) => method.ToUpper() switch
    {
        "GET" => Color.Info,
        "POST" => Color.Success,
        "PUT" => Color.Warning,
        "DELETE" => Color.Error,
        _ => Color.Default
    };

    private Color GetStatusColor(int status) => status switch
    {
        >= 200 and < 300 => Color.Success,
        >= 400 and < 500 => Color.Warning,
        >= 500 => Color.Error,
        _ => Color.Default
    };



    public class TrafficLog // Must match WatchLog shape on the server
    {
        public DateTime Timestamp { get; set; } = DateTime.Now; // Default to now as server doesn't send it currently
        public string Method { get; set; } = "";
        public string Path { get; set; } = "";
        // Note: The server WatchLog doesn't currently store StatusCode, 
        // we might need to add it to WatchLog or omit it here.
        public int StatusCode { get; set; } = 200; 
    }
}
